# Dependencies - these are downloaded via npm/yarn and should not be in your repo
/node_modules
/.pnp
.pnp.js

# Testing - coverage reports generated by test runners
/coverage

# Production Build - the compiled output for deployment
/build
/dist

# Environment Variables - MUST be ignored as they often contain secret keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs - debug information generated during development
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Editor/OS Specific - local settings for your IDE or Operating System
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
